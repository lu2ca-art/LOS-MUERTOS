# Opensquad — chaves de API dos squads Arquiteto Visual e Gestor Vila
# Copie este arquivo para .env e preencha os valores reais.
# .env é ignorado pelo git — nunca commite chaves de verdade.

# Blotato — publicação/agendamento em redes sociais (skill: blotato)
BLOTATO_API_KEY=

# Instagram Graph API — publisher de carrossel (skill: instagram-publisher)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# imgBB — hospedagem pública das imagens antes de publicar no Instagram (skill: instagram-publisher)
IMGBB_API_KEY=
